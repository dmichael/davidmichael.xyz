---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  subtitle?: string;
  credits?: string;
  hero: string | null;
  heroFocus?: string;
  images: string[];
  textBlocks: string[];
  imgBase: string;
}

const { title, subtitle, credits, hero, heroFocus = "50% 50%", images, textBlocks, imgBase } = Astro.props;
---

<BaseLayout title={`${title} - David Michael`} heroOverlay={!!hero}>
  {hero ? (
    <section class="hero-banner">
      <img
        class="hero-banner__img"
        style={`--hero-focus: ${heroFocus}`}
        src={`${imgBase}/${hero}`}
        alt={title}
        loading="eager"
      />
      <div class="hero-banner__content">
        <h1 class="hero-banner__title">{title}</h1>
        {subtitle && <p class="hero-banner__subtitle">{subtitle}</p>}
      </div>
    </section>
  ) : (
    <section class="title-section">
      <h1 class="title-section__title">{title}</h1>
      {subtitle && <p class="title-section__subtitle">{subtitle}</p>}
    </section>
  )}

  <article class="content">
    {credits && (
      <p class="content__credits">{credits}</p>
    )}

    {textBlocks.map((block, i) => (
      <div class="content__section">
        {images[i] && (
          <div class="content__image">
            <img src={`${imgBase}/${images[i]}`} alt="" loading="lazy" />
          </div>
        )}
        <p class:list={["content__text", { "content__text--lead": i === 0 }]}>{block}</p>
      </div>
    ))}

    {images.slice(textBlocks.length).map((img) => (
      <div class="content__image content__image--standalone">
        <img src={`${imgBase}/${img}`} alt="" loading="lazy" />
      </div>
    ))}
  </article>
</BaseLayout>

<style>
  .hero-banner {
    position: relative;
    width: 100%;
    height: 55vh;
    min-height: 350px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    padding: 2rem var(--horizontal-padding);
    margin-top: -80px;
  }

  .hero-banner__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--hero-focus, 50% 50%);
    z-index: 0;
  }

  .hero-banner__content {
    position: relative;
    z-index: 1;
    max-width: var(--max-page-width);
    margin: 0 auto;
    width: 100%;
  }

  .hero-banner__title {
    color: #fff;
    font-size: min(3.375rem, 1rem + 2.64vw);
    font-weight: 400;
    line-height: 1.3;
  }

  .hero-banner__subtitle {
    color: rgba(255, 255, 255, 0.8);
    font-size: min(1rem, 1rem + 0vw);
    letter-spacing: 0.19em;
    text-transform: uppercase;
    margin-top: 0.5rem;
  }

  .title-section {
    padding: 8rem var(--horizontal-padding) 3rem;
    max-width: var(--max-page-width);
    margin: 0 auto;
    text-align: center;
  }

  .title-section__title {
    font-size: min(3.375rem, 1rem + 2.64vw);
    font-weight: 400;
    line-height: 1.3;
  }

  .title-section__subtitle {
    font-size: min(1rem, 1rem + 0vw);
    letter-spacing: 0.19em;
    text-transform: uppercase;
    margin-top: 0.75rem;
    color: var(--primary-paragraphs);
    opacity: 0.7;
  }

  .content {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem var(--horizontal-padding) 4rem;
  }

  .content__credits {
    font-size: min(0.875rem, 1rem - 0.14vw);
    line-height: 1.6;
    color: var(--primary-paragraphs);
    opacity: 0.6;
    margin-bottom: 3rem;
    text-align: center;
  }

  .content__section {
    margin-bottom: 3rem;
  }

  .content__text {
    font-size: min(1.125rem, 1rem + 0.14vw);
    line-height: 1.78;
    color: var(--primary-paragraphs);
  }

  .content__text--lead {
    font-size: min(1.5rem, 1rem + 0.56vw);
    line-height: 1.5;
    text-align: center;
    margin-bottom: 3rem;
  }

  .content__image {
    margin: 2rem 0;
  }

  .content__image img {
    width: 100%;
    display: block;
  }

  .content__image--standalone {
    margin: 3rem 0;
  }

  @media (max-width: 767px) {
    .hero-banner {
      height: 40vh;
    }
  }
</style>
